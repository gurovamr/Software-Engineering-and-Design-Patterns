@startuml uml_session_loading
title F1 Telemetry Dashboard - DB-First Session Loading

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam shadowing false
skinparam wrapWidth 180
skinparam ArrowColor #444444
skinparam ParticipantPadding 25
skinparam BoxPadding 12

box "Dash Application Layer" #E8F1FF
participant "DashboardCallbackRegistry\nDash callbacks" as Dash
end box

box "Domain and Service Layer" #EAF8EA
participant "SessionService\nDB-first facade" as Service
end box

box "Persistence Layer - SQLite" #F7E8FF
database "SessionRepository\nsessions table" as Repo
end box

box "FastF1 Data Layer" #FFE8E8
participant "F1SessionBundleCache\nprocess cache" as ProcessCache
participant "FastF1Source\nadapter" as Source
collections "cache/\nFastF1 HTTP cache" as HttpCache
participant "FastF1 API" as API
end box

Dash -> Service : 1. load selected session or full event
activate Service
Service -> Repo : 2. load_session(year, event, session_code)
Repo --> Service : existing TelemetryBundle or None

alt session already stored locally
  Service -> Service : build SessionLoadResult DTO
else session missing locally
  Service -> Service : build SessionRequest DTO
  Service -> ProcessCache : 3. load_quick(), load_full(), or load_driver_telemetry()
  activate ProcessCache
  ProcessCache -> Source : load_bundle(request)
  activate Source
  Source -> HttpCache : _enable_fastf1_cache(cache_dir)
  Source -> API : fetch selected FastF1 session data
  API --> Source : results, laps, telemetry
  Source --> ProcessCache : normalized TelemetryBundle
  deactivate Source
  ProcessCache --> Service : TelemetryBundle
  deactivate ProcessCache
  Service -> Repo : 4. save_session(bundle)
  Service -> Service : build SessionLoadResult DTO
end

Dash -> Service : 5. load selected-driver telemetry
Service -> Repo : load_session(..., selected drivers/laps)
Repo --> Service : merged telemetry for selected drivers
Service -> Service : build DriverTelemetryResult DTO
Service --> Dash : 6. callback state, figures, and user feedback
deactivate Service

note right of Service
DTOs used by callbacks:
SessionRequest
TelemetryBundle
SessionLoadResult
DriverTelemetryResult
EventCacheResult
end note

note over Repo
sessions columns:
year, event, session_code
session_info
results_json, laps_json, telemetry_json

ensure_schema() migrates older local DBs by adding session_info.
end note

legend bottom
|= Step |= Meaning |
| 1 | The user action reaches SessionService through Dash callbacks. |
| 2 | SQLite is checked before any FastF1 request. |
| 3 | FastF1 is contacted only when local data is missing or the user explicitly loads a full event. |
| 4 | Fresh FastF1 data is persisted so later loads can stay local. |
| 5 | Telemetry plots read the selected drivers and laps from the cached SQLite bundle. |
| 6 | The callback updates visible status text, tables, and charts. |
endlegend

@enduml

@startuml uml_dash_lap_logic
title F1 Telemetry Dashboard - Current Dash Lap Logic

top to bottom direction

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60
skinparam shadowing false
skinparam wrapWidth 170
skinparam ArrowColor #444444
skinparam packageTitleAlignment center

rectangle "Driver Selection" as DRIVER #E8F1FF {
  component "Finishing Order table\nselect up to 3 drivers\nfavorite driver selected by default" as ResultsTable
  component "Selected drivers status\nprevents more than 3 selections" as SelectedStatus
}

rectangle "Lap Overview" as LAPS #EAF8EA {
  component "Lap time comparison plot\nshows all laps for selected drivers" as LapSummary
  component "Per-driver lap tables\none table per selected driver\n10 fastest laps by default" as LapTables
}

rectangle "Telemetry Analysis" as TELEMETRY #FFF5D7 {
  component "Selected lap rows\nchoose exact laps per driver" as SelectedRows
  component "Speed over distance" as SpeedChart
  component "Gear over distance\naxis starts at gear 1" as GearChart
  component "Throttle and brake over distance" as InputsChart
}

rectangle "Track Maps" as MAPS #FFE8E8 {
  component "Track lap dropdowns\none dropdown per selected driver\nfastest lap by default" as TrackDropdowns
  component "Speed-colored track maps\none column per selected driver" as TrackMap
  component "Gear-shift track maps\none column per selected driver" as GearMap
}

rectangle "Race Overview" as RACE #F7E8FF {
  component "Race timeline / position chart" as Timeline
  component "Key events\ncolored with team palette when available" as KeyEvents
  component "Tyre strategy, team pace,\nlap-time distribution" as RaceCharts
}

ResultsTable -down-> LapSummary : selected drivers
ResultsTable -down-> LapTables : selected drivers
LapTables -down-> SelectedRows : selected lap rows
SelectedRows -down-> SpeedChart
SelectedRows -down-> GearChart
SelectedRows -down-> InputsChart

ResultsTable -right-> TrackDropdowns : selected drivers
TrackDropdowns -down-> TrackMap : selected map lap
TrackDropdowns -down-> GearMap : selected map lap

ResultsTable -right..> SelectedStatus
Timeline -right..> KeyEvents
Timeline -down..> RaceCharts

legend bottom
|= Area |= User-facing behavior |
| Driver selection | The finishing order table is the single driver-selection control for analysis. |
| Lap overview | The lap plot shows every lap; the per-driver tables show the fastest 10 by default. |
| Telemetry analysis | Telemetry plots use the exact lap rows selected in the per-driver tables. |
| Track maps | Track maps use separate per-driver dropdowns because overlaying map laps was unreadable. |
| Race overview | Whole-race charts stay separate from selected-driver analysis. |
endlegend

@enduml
