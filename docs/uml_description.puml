@startuml uml_architecture_overview
title F1 Telemetry Dashboard - Architecture Overview

top to bottom direction

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 55
skinparam ranksep 65
skinparam shadowing false
skinparam wrapWidth 160
skinparam ArrowColor #444444
skinparam packageTitleAlignment center

rectangle "Dash Application Layer" as APP #E8F1FF {
  component "DashApp\ncreates services and registers callbacks" as DashApp
  component "DashboardCallbackRegistry\nlogin, session loading, lap selection" as Callbacks
  component "DashLayout\nbuilds controls, tables, and graph slots" as Layout
}

rectangle "Visualization Layer" as VIS #FFF5D7 {
  component "Plotly Chart Classes\nrace overview, driver analysis, track maps" as Charts
  component "F1ColorPalette\nteam, tyre, and gear colors" as Colors
}

rectangle "Domain and Service Layer" as DOMAIN #EAF8EA {
  component "AuthService" as AuthService
  component "DriverService" as DriverService
  component "SessionService\nDB-first session facade" as SessionService
  component "TelemetryService" as TelemetryService
  component "DataLoader" as DataLoader
}

database "Persistence Layer - SQLite\nusers, drivers, tracks, sync_state, sessions" as SQLITE #F7E8FF
cloud "FastF1 Data Layer\nFastF1 API plus local cache/" as FASTF1 #FFE8E8
component "DTOs\nTelemetryBundle, SessionRequest,\nSessionLoadResult, DriverTelemetryResult,\nEventCacheResult" as DTO #F2F2F2

APP -down-> DOMAIN : 1
DOMAIN -down-> SQLITE : 2
DOMAIN -right-> FASTF1 : 3
DOMAIN -right..> DTO : 4
APP -right..> VIS : 5

DashApp -down-> Layout
DashApp -down-> Callbacks
Charts -down..> Colors

legend bottom
|= Step |= Runtime meaning |
| 1 | Dash callbacks use injected services for auth, driver suggestions, full-event loading, and session loading. |
| 2 | SQLite is the first source for app data and cached FastF1 session data. |
| 3 | FastF1 is called on demand, only when the selected session/event is missing locally. |
| 4 | Services move structured results through DTOs instead of loose callback dictionaries. |
| 5 | Dash callbacks delegate chart construction to visualization classes and color utilities. |
endlegend

@enduml

@startuml uml_description
title F1 Telemetry Dashboard - Detailed UML Description

top to bottom direction

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60
skinparam shadowing false
skinparam monochrome false
skinparam wrapWidth 180
skinparam packageTitleAlignment center
skinparam ArrowColor #444444

hide empty fields

package "Dash Application Layer" as DETAIL_APP {
  class DashApp <<entry point>> {
    +app: Dash
    +server: Flask
    +create services
    +register callbacks
  }

  class DashLayout <<UI factory module>> {
    +create_layout(): Component
    -_login_page(): Component
    -_dashboard_page(): Component
    -_results_table(): Component
    -_lap_table_panel(index): Component
  }

  class DashboardCallbackRegistry <<controller facade>> {
    -auth_service: AuthService
    -driver_service: DriverService
    -data_loader: DataLoader
    -session_service: SessionService
    -session_cache: dict
    +register(app): void
    --
    -select up to 3 drivers
    -build top-10 lap tables
    -build telemetry charts
    -build side-by-side track maps
  }

  class LapSelectionPanels <<Dash component group>> {
    +results_table: DataTable
    +lap_summary_graph: Graph
    +per_driver_lap_tables: DataTable[3]
    +track_lap_dropdowns: Dropdown[3]
    --
    +summary graph shows all selected-driver laps
    +driver tables show top 10 fastest laps
    +fastest lap is selected by default
    +selected rows drive telemetry plots
  }
}

package "Domain and Service Layer" as DETAIL_DOMAIN {
  class AuthService <<service>> {
    -repo: UserRepository
    +register(...): tuple
    +login(...): tuple
    +update_favorite_driver(...): void
  }

  class DriverService <<service>> {
    -repo: DriverRepository
    -user_repo: UserRepository
    +get_all_driver_codes(): list[str]
    +save_driver_codes(...): void
    +refresh_known_driver_codes(...): list[str]
    +get_popular_drivers(...): list[str]
  }

  class SessionService <<DB-first service facade>> {
    -repo: SessionRepository
    -cache_dir: Path
    +load_session_overview(...): SessionLoadResult
    +load_driver_telemetry(...): DriverTelemetryResult
    +cache_full_event(...): EventCacheResult
    --
    +read SQLite first
    +fetch FastF1 only when missing
    +merge telemetry into SQLite
  }

  class TelemetryService <<service>> {
    +get_available_drivers(): list[str]
    +get_driver_laps(...): list[int]
    +get_multiple_laps_telemetry(...): DataFrame
    +get_lap_summary(...): DataFrame
  }

  class PitStopExtractor <<utility service>> {
    {static} +extract(laps_df): list[dict]
  }

  class DataLoader <<singleton>> {
    +begin_sync(year): void
    +get_sync_status(): dict
  }
}

package "Persistence Layer - SQLite" as DETAIL_DB {
  abstract class BaseRepository <<repository base>> {
    -db_path: Path
    #_connect(): Iterator[Connection]
  }

  class UserRepository <<repository>> {
    +ensure_schema(): void
    +find_by_name(...): dict
    +create(...): int
    +update_favorite_driver(...): void
  }

  class DriverRepository <<repository>> {
    +ensure_schema(): void
    +upsert_driver_codes(...): void
    +get_all_driver_codes(): list[str]
  }

  class TrackRepository <<repository>> {
    +ensure_schema(): void
    +get_events(year): list[str]
    +upsert_event_names(...): void
  }

  class SessionRepository <<local session store>> {
    +ensure_schema(): void
    +load_session(...): TelemetryBundle
    +save_session(...): void
    -_merge_telemetry(...): DataFrame
    --
    sessions:
    year, event, session_code
    session_info
    results_json, laps_json
    telemetry_json
    --
    migration adds missing session_info
  }

  class SyncRepository <<repository>> {
    +ensure_schema(): void
    +get_state(year): dict
    +save_state(...): void
  }
}

package "FastF1 Data Layer" as DETAIL_F1 {
  class FastF1CacheHelper <<module function>> {
    {static} +_enable_fastf1_cache(cache_dir): Path
    --
    +create cache directory
    +enable FastF1 cache
  }

  abstract class TelemetrySource <<adapter interface>> {
    +load_bundle(request): TelemetryBundle
  }

  class FastF1Source <<adapter>> {
    -cache_dir: Path
    +load_bundle(request): TelemetryBundle
    -_normalize_results(...): DataFrame
    -_normalize_laps(...): DataFrame
    -_build_telemetry_dataframe(...): DataFrame
  }

  class F1SessionBundleCache <<process cache facade>> {
    -cache: dict
    +load_quick(...): TelemetryBundle
    +load_driver_telemetry(...): DataFrame
    +load_full(...): TelemetryBundle
  }

  class F1ScheduleService <<schedule facade>> {
    -event_cache: dict
    +get_events(year): list[str]
    +get_events_with_laps(...): list[str]
  }
}

package "Data Transfer Objects" as DETAIL_DTO {
  class TelemetryBundle <<DTO>> {
    +session_info: dict
    +results: DataFrame
    +laps: DataFrame
    +telemetry: DataFrame
  }

  class SessionRequest <<value object>> {
    +year: int
    +event: str | int
    +session_code: str
    +drivers: list[str]
  }

  class SessionLoadResult <<DTO>>
  class DriverTelemetryResult <<DTO>>
  class EventCacheResult <<DTO>>
}

package "Visualization Layer" as DETAIL_VIS {
  abstract class BaseChart <<template method>> {
    +render(): Figure
    #_build(): Figure
    {static} +empty_figure(...): Figure
  }

  class TelemetryCharts <<chart family>> {
    +LapSummaryChart
    +SpeedChart
    +GearChart
    +ThrottleBrakeChart
    +TrackMapChart
    +GearMapChart
    +PositionChart
    +TyreStrategyChart
    +TeamPaceChart
    +LapTimesDistributionChart
  }

  class F1ColorPalette <<utility>> {
    {static} +get_team_color(...): str
    {static} +get_compound_color(...): str
    {static} +get_gear_color(...): str
  }
}

DashApp --> DashLayout
DashApp --> DashboardCallbackRegistry
DashLayout *-- LapSelectionPanels
DashboardCallbackRegistry --> LapSelectionPanels

DashboardCallbackRegistry --> AuthService
DashboardCallbackRegistry --> DriverService
DashboardCallbackRegistry --> DataLoader
DashboardCallbackRegistry --> SessionService
DashboardCallbackRegistry ..> TelemetryService
DashboardCallbackRegistry ..> PitStopExtractor
DashboardCallbackRegistry ..> TelemetryCharts
DashboardCallbackRegistry ..> F1ColorPalette

AuthService *-- UserRepository
DriverService *-- DriverRepository
DriverService --> UserRepository
SessionService *-- SessionRepository
SessionService ..> F1SessionBundleCache
SessionService ..> SessionRequest
SessionService ..> SessionLoadResult
SessionService ..> DriverTelemetryResult
SessionService ..> EventCacheResult
DataLoader --> SyncRepository
DataLoader ..> F1ScheduleService

BaseRepository <|-- UserRepository
BaseRepository <|-- DriverRepository
BaseRepository <|-- TrackRepository
BaseRepository <|-- SessionRepository
BaseRepository <|-- SyncRepository

SessionRepository ..> TelemetryBundle
F1SessionBundleCache *-- FastF1Source
F1SessionBundleCache ..> FastF1CacheHelper
F1ScheduleService ..> FastF1CacheHelper
FastF1Source --|> TelemetrySource
FastF1Source ..> FastF1CacheHelper
FastF1Source ..> TelemetryBundle

TelemetryCharts --|> BaseChart
TelemetryCharts ..> F1ColorPalette

legend bottom
|= Arrow |= Meaning |
| solid arrow | Main runtime flow / direct collaboration |
| dashed arrow | Secondary dependency, helper, or generated data |
| black diamond | Composition / owned object |
| hollow triangle | Inheritance or interface implementation |
| Dash -> Domain | Callbacks use injected services for auth, drivers, sync, sessions, metrics, and pit-stop extraction |
| Domain -> SQLite | Services own repositories for user, driver, track, sync, and local session data |
| Domain -> FastF1 | SessionService calls FastF1 only when SQLite is missing overview or driver telemetry |
| Dash -> Visualization | Callbacks build Plotly figures through chart classes and F1ColorPalette |
| Lap analysis | Finishing order selects drivers; top-10 lap tables select telemetry laps; track dropdowns select map laps |
| Generated outputs | HTML/PNG renders live in docs/generated/ |
endlegend

@enduml

